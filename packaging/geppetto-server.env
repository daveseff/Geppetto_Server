# Environment for geppetto-server.service.
# Keep server state separate from agent config under /etc/geppetto.
GEPPETTO_SERVER_BASE=/etc/geppetto_server
GEPPETTO_SERVER_HOST=0.0.0.0
GEPPETTO_SERVER_PORT=8443
GEPPETTO_SERVER_LOG_FILE=/var/log/geppetto/geppetto-server.log
# GEPPETTO_SERVER_NAME=config.example.com
# GEPPETTO_SERVER_PATH_PREFIX=/geppetto
# Comma-separated additional DNS names for the server certificate SAN.
# GEPPETTO_SERVER_ALT_NAMES=config,config.example.com

# Optional overrides:
# GEPPETTO_CONFIG_ROOT=/etc/geppetto_server/config
# GEPPETTO_SERVER_CERT=/etc/geppetto_server/pki/server.crt
# GEPPETTO_SERVER_KEY=/etc/geppetto_server/pki/server.key
# GEPPETTO_CA_CERT=/etc/geppetto_server/pki/ca.crt
# GEPPETTO_CA_KEY=/etc/geppetto_server/pki/ca.key
# GEPPETTO_PENDING_CSR_DIR=/etc/geppetto_server/csr_pending
# GEPPETTO_SIGNED_CERT_DIR=/etc/geppetto_server/certs
# GEPPETTO_AUTOSIGN=false
